[Unit]
Description=JamShield ESP-NOW bridge (USB receiver board -> MQTT)
After=network.target mosquitto.service

[Service]
User=prathvi
ExecStart=/home/prathvi/jamshield_env/bin/python /home/prathvi/jamshield/scripts/espnow_bridge.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

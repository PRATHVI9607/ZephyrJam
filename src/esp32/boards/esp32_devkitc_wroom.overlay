/*
 * JamShield — ESP32 DevKit V1 device-tree overlay.
 * LDR voltage divider on GPIO34 = ADC1 channel 6. Built-in LED on GPIO2.
 *
 * The ADC channel is consumed via the standard "zephyr,user" node so the app
 * uses ADC_DT_SPEC_GET(DT_PATH(zephyr_user)). The ADC node label is verified
 * against the SoC DTS for this Zephyr version (see scripts/verify_dts notes).
 */
/ {
	zephyr,user {
		io-channels = <&adc0 6>;
	};

	aliases {
		led0 = &led_builtin;
	};

	leds {
		compatible = "gpio-leds";
		led_builtin: led_0 {
			gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>;
			label = "Built-in LED";
		};
	};
};

/* adc0 = ESP32 ADC unit 1; GPIO34 is ADC1_CH6 (verified against SoC DTS). */
&adc0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@6 {
		reg = <6>;
		zephyr,gain = "ADC_GAIN_1_4";          /* ~11 dB atten -> 0..3.3V */
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&wifi {
	status = "okay";
};
